# Copy this file to .env.local and fill in values, then restart `npm run dev`.
#
#   cp .env.example .env.local

# ── Gemini (dev/preview server middleware only) ──────────────────────────────
# Used ONLY by the dev/preview server middleware (see vite.config.ts and
# vite-plugins/generateRoadmapApi.ts). Never bundled into client code.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Supabase (account-linked profile persistence) ────────────────────────────
# Optional: leave blank to run on the local dev fallback store. When both are
# set, profiles are stored per-user in Postgres with row-level security.
# See docs/SETUP.md. Only the PUBLIC url + anon key belong here (RLS protects
# data; the service-role key must never be placed in client env).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
